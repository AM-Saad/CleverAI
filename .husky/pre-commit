#!/usr/bin/env sh
# Block raw design values (hex, palette classes, built-in radius/shadow) before
# they land. Fast (<1s) whole-tree scan. See docs/DESIGN_SYSTEM.md; use a
# `design-allow` comment on a line for a justified exception.
yarn design:check
yarn design:tokens:check
yarn design:states
yarn design:primitives
yarn design:primitives:unused
yarn design:api
yarn design:boundaries
